# Copy this file to .env and fill in your values.

# OPENAI_API_KEY — your key for the endpoint below.
# For a local Ollama, any non-empty string works (it is ignored).
OPENAI_API_KEY=ollama

# MODEL — the CHAT model that writes the answers, spelled the way your provider spells it.
MODEL=qwen3:1.7b

# EMBED_MODEL — the EMBEDDINGS model that turns text into vectors.
EMBED_MODEL=nomic-embed-text

# OPENAI_ENDPOINT — base URL of any OpenAI-compatible API. Point it elsewhere to use a
# different provider (then adjust MODEL and EMBED_MODEL to that provider's spelling):
#   local Ollama:  http://localhost:11434/v1  (MODEL=qwen3:1.7b, EMBED_MODEL=nomic-embed-text)
#   OpenAI:        https://api.openai.com/v1   (MODEL=gpt-4.1-mini, EMBED_MODEL=text-embedding-3-small)
OPENAI_ENDPOINT=http://localhost:11434/v1

# The RAG knobs — optional, sensible defaults live in the code.
# CHUNK_SIZE=320
# CHUNK_OVERLAP=40
# TOP_K=3
