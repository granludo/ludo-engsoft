# Copy this file to .env and fill in your values.

# OPENAI_API_KEY — your key for the endpoint below.
OPENAI_API_KEY=sk-your-key-here

# MODEL — the model name, spelled the way your provider spells it.
# (Function calling needs a model that supports tools — most current ones do.)
MODEL=gpt-4.1-mini

# OPENAI_ENDPOINT — base URL of any OpenAI-compatible API. Point it elsewhere to
# use a different provider (then adjust MODEL to that provider's spelling):
#   OpenAI:        https://api.openai.com/v1   (MODEL=gpt-4.1-mini)
#   OpenRouter:    https://openrouter.ai/api/v1 (MODEL=openai/gpt-4.1-mini)
#   local Ollama:  http://localhost:11434/v1
#   Azure OpenAI:  https://your-resource.openai.azure.com/v1
OPENAI_ENDPOINT=https://api.openai.com/v1
